# Guard server listen address
GUARD_ADDR=:8080

# Node.js backend to proxy to
UPSTREAM_URL=http://localhost:3000

# Python agent server (/agents/* routes)
AGENT_URL=http://localhost:4000

# Comma-separated Bearer tokens with optional client names: token:name,token2:name2
# Leave empty to disable auth (dev only)
API_KEYS=supersecrettoken:ios-app,anothertoken:web-client

# Comma-separated allowed origins (empty = allow all, dev mode)
ALLOWED_ORIGINS=

# Per-client rate limit: sustained requests per second and burst size
RATE_LIMIT_RPS=2
RATE_BURST=10
